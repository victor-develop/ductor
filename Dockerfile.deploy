FROM node:22-bookworm-slim

ENV DEBIAN_FRONTEND=noninteractive \
    LANG=en_US.UTF-8 \
    LC_ALL=en_US.UTF-8 \
    PYTHONUNBUFFERED=1 \
    PIP_BREAK_SYSTEM_PACKAGES=1 \
    HOME=/home/node \
    DUCTOR_HOME=/home/node/.ductor-slack

RUN apt-get update \
    && apt-get install -y --no-install-recommends \
       python3 python3-pip python3-venv python3-dev \
       build-essential git curl ca-certificates tini locales \
    && sed -i '/en_US.UTF-8/s/^# //' /etc/locale.gen && locale-gen \
    && rm -rf /var/lib/apt/lists/*

RUN rm -f /usr/lib/python*/EXTERNALLY-MANAGED

RUN npm install -g @anthropic-ai/claude-code @openai/codex @google/gemini-cli

WORKDIR /app

COPY . /app

RUN python3 -m pip install --no-cache-dir ".[slack,matrix,api]"

RUN mkdir -p /home/node/.ductor-slack /home/node/.claude /home/node/.codex /home/node/.gemini \
              /home/node/.cache/claude-cli-nodejs /home/node/.config /workspace \
    && chown -R node:node /app /home/node

WORKDIR /workspace

COPY docker-entrypoint.sh /usr/local/bin/ductor-slack-entrypoint
RUN chmod +x /usr/local/bin/ductor-slack-entrypoint

USER node

VOLUME ["/home/node/.ductor-slack", "/home/node/.claude", "/home/node/.codex", "/home/node/.gemini", "/workspace"]

ENTRYPOINT ["tini", "--", "/usr/local/bin/ductor-slack-entrypoint"]
CMD ["ductor-slack"]
